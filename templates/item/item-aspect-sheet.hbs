<form class="{{cssClass}}" autocomplete="off">
    <header class="sheet-header itemHeader">
        <img class="item-img" src="{{item.img}}" data-action="editImage" data-field="img" title="{{item.name}}"/>
        <div class="header-fields">
            <h1 class="charname">
                <input name="name" type="text" value="{{item.name}}" placeholder="Name"/>
            </h1>
            <div class="grid grid-2col">
            </div>
        </div>
    </header>

    <nav class="sheet-tabs itemnav tabs" data-group="primary">
        {{#each tabs.primary as |tab|}}
            {{#if (eq tab.id "effects")}}
                {{#if @root.item.showEffectsTab}}
                    <a class="item {{#if tab.active}}active{{/if}}" data-action="tab" data-group="primary" data-tab="{{tab.id}}">
                        {{localize tab.label}}
                    </a>
                {{/if}}
            {{else}}
                <a class="item {{#if tab.active}}active{{/if}}" data-action="tab" data-group="primary" data-tab="{{tab.id}}">
                    {{localize tab.label}}
                </a>
            {{/if}}
        {{/each}}
    </nav>

    <section class="item-sheet-body" style="min-height: 240px; height: fit-content;">
        <div class="tab {{#if (eq tabGroups.primary 'details')}}active{{/if}}" data-group="primary" data-tab="details">
            <div class="flexrow flex-group-center">
                {{#if item.homebrew}}
                <table>
                    <tr>
                        <td>
                            <label class="resource-label">Psi Type</label>
                        </td>
                        <td>
                            <label class="resource-label">Infection Modifier</label>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <select name="system.psiType" data-type="String">
                                {{selectOptions config.psiTypes selected=item.system.psiType localize=true}}
                            </select>
                        </td>
                        <td>
                            <input class="input-large" type="number" name="system.infection" value="{{item.system.infection}}" placeholder="e.g. 3"/>
                        </td>
                    </tr>
                </table>
                {{else}}
                <table>
                    <tr>
                        <td>
                            <label class="resource-label">{{localize "ep2e.item.aspect.table.type.label"}}</label>
                        </td>
                        {{#if (eq item.system.psiType "chi")}}
                        {{else}}
                        <td>
                            <label class="resource-label">{{localize "ep2e.item.aspect.table.action.label"}}</label>
                        </td>
                        <td>
                            <label class="resource-label">{{localize "ep2e.item.aspect.table.duration.label"}}</label>
                        </td>
                        {{/if}}
                        <td>
                            <label class="resource-label">{{localize "ep2e.item.aspect.table.modifierLabel"}}</label>
                        </td>
                    </tr>
                    <tr>
                        <td>
                            <select name="system.psiType" data-type="String">
                                {{selectOptions config.psiTypes selected=item.system.psiType localize=true}}
                            </select>
                        </td>
                        {{#if (eq item.system.psiType "chi")}}
                        {{else}}
                        <td>
                            <select name="system.actionType" data-type="String">
                                {{selectOptions config.actionTypes selected=item.system.actionType localize=true}}
                            </select>
                        </td>
                        <td>
                            <select name="system.duration" data-type="String">
                                {{selectOptions config.duration selected=item.system.duration localize=true}}
                            </select>
                        </td>
                        {{/if}}
                        <td>
                            {{#if (eq item.system.psiType "chi")}}
                            -
                            {{else}}
                            <input class="input-large" type="number" name="system.infection" value="{{item.system.infection}}" placeholder="e.g. 3"/>
                            {{/if}}
                        </td>
                    </tr>
                </table>
                {{/if}}
            </div>
        </div>

        <div class="tab {{#if (eq tabGroups.primary 'description')}}active{{/if}}" data-group="primary" data-tab="description">
            {{#if editable}}
                <prose-mirror
                    name="system.description"
                    button="true"
                    editable="true"
                    toggled="false"
                    value="{{item.system.description}}">
                    {{{htmlDescription}}}
                </prose-mirror>
            {{else}}
                {{{htmlDescription}}}
            {{/if}}
        </div>

        <div class="tab {{#if (eq tabGroups.primary 'effects')}}active{{/if}}" data-group="primary" data-tab="effects">
            {{> systems/eclipsephase/templates/actor/partials/tabs/gm-info-tab.html}}
        </div>
    </section>
</form>