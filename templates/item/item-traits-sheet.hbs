<form class="{{cssClass}}" autocomplete="off">
    <header class="sheet-header itemHeader">
        <div class="header-fields flexgrow flex-group-left" style="align-items: flex-end;">
            <img class="item-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
            <h1 class="charname">
                <input name="name" type="text" value="{{item.name}}" placeholder="Name"/>
            </h1>
        </div>
    </header>

    <nav class="sheet-tabs itemnav tabs" data-group="primary">
        {{#each tabs.primary as |tab|}}
            {{#if (eq tab.id "effects")}}
                {{#if @root.item.showEffectsTab}}
                    <a class="item {{#if tab.active}}active{{/if}}" data-action="tab" data-group="primary" data-tab="{{tab.id}}">
                        {{localize tab.label}}
                    </a>
                {{/if}}
            {{else if (eq tab.id "details")}}
                <a class="item {{#if tab.active}}active{{/if}}" data-action="tab" data-group="primary" data-tab="{{tab.id}}">
                    {{localize "ep2e.item.general.table.description"}}
                </a>
            {{/if}}
        {{/each}}
    </nav>

    <section class="item-sheet-body">
        <div class="tab {{#if (eq tabGroups.primary 'details')}}active{{/if}}" data-group="primary" data-tab="details" style="padding: none;">
            <div style="background-color: var(--mainBackground);">
                <div class="item contentBox" data-item-id="{{item.id}}" data-item-name="{{item.name}}" style="padding-bottom: 5px;">
                    <div class="flexrow">
                        <h3 class="subheader dialog">
                            Trait Type
                        </h3>
                        <div class="alignRight flexGrowHalf">
                        </div>
                    </div>
                </div>
                <div class="flexrow flex-group-center listBackground grid" style="background-color: var(--pitchBorder); margin: 0; border-top: solid var(--accentBackground) 3px">
                    <div class="flexrow flex-group-left">
                        {{radioBoxes "system.traitType" config.traitTypes checked=item.system.traitType localize=true}}
                    </div>
                    <div class="flexrow flex-group-left">
                        <input style="margin:auto; display:flex; margin: 5px 15px;" type="checkbox" class="rest" id="egoCheckbox" name="system.ego" {{checked item.system.ego}}/>
                        <label class="resource-sub-label" for="egoCheckbox">{{localize "ep2e.actorSheet.leftTabs.egoTab"}}</label>
                        <input style="margin:auto; display:flex; margin: 5px 15px;" type="checkbox" class="rest" id="morphCheckbox" name="system.morph" {{checked item.system.morph}}/>
                        <label class="resource-sub-label" for="morphCheckbox">{{localize "ep2e.actorSheet.rightTabs.morphTab"}}</label>
                    </div>
                </div>
            </div>

            {{#if editable}}
                <prose-mirror
                    name="system.description"
                    button="true"
                    editable="true"
                    toggled="false"
                    value="{{item.system.description}}">
                    {{{htmlDescription}}}
                </prose-mirror>
            {{else}}
                {{{htmlDescription}}}
            {{/if}}
        </div>

        <div class="tab {{#if (eq tabGroups.primary 'effects')}}active{{/if}}" data-group="primary" data-tab="effects">
            {{> systems/eclipsephase/templates/actor/partials/tabs/gm-info-tab.html}}
        </div>
    </section>
</form>